{
  "name": "@arinc424/toolkit",
  "version": "0.1.6",
  "description": "Convenience metapackage bundling core, features, procedures, analysis, tiles, 3D tiles, view APIs, and the arinc CLI.",
  "type": "module",
  "license": "MIT",
  "main": "./src/index.js",
  "bin": {
    "arinc": "./bin/arinc.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./cli": "./src/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mploscos/arinc424-toolkit.git",
    "directory": "packages/toolkit"
  },
  "homepage": "https://github.com/mploscos/arinc424-toolkit#readme",
  "bugs": {
    "url": "https://github.com/mploscos/arinc424-toolkit/issues"
  },
  "keywords": [
    "arinc424",
    "aviation",
    "navigation",
    "monorepo",
    "toolkit"
  ],
  "files": [
    "bin",
    "src",
    "README.md"
  ],
  "dependencies": {
    "@arinc424/3dtiles": "0.1.6",
    "@arinc424/analysis": "0.1.6",
    "@arinc424/core": "0.1.6",
    "@arinc424/features": "0.1.6",
    "@arinc424/procedures": "0.1.6",
    "@arinc424/tiles": "0.1.6",
    "@arinc424/view": "0.1.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node --test test/**/*.test.js",
    "test:golden": "node -e \"console.log('No golden tests for @arinc424/toolkit')\"",
    "bench": "node -e \"console.log('No benchmark for @arinc424/toolkit')\""
  }
}
